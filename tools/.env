# ~/ADKAgent/PESAgent/.env
# -------------------------------
# LOCAL DEVELOPMENT TEMPLATE ONLY
# Do not commit real secrets.
# In cloud, set:
#   PES_CLIENT_ID_SECRET
#   PES_CLIENT_SECRET_SECRET
# -------------------------------

# --- PES OAuth and API endpoints ---
PESOAUTH_URL=https://api-stg.uhg.com/oauth2/token
PES_GRAPHQL_URL=https://api-stg.uhg.com/api/provider/demographics/practitioner/1.0.0

# --- Client credentials (local fallback ONLY) ---
# Prefer Secret Manager in cloud:
#   PES_CLIENT_ID_SECRET=projects/<proj>/secrets/PES_CLIENT_ID/versions/latest
#   PES_CLIENT_SECRET_SECRET=projects/<proj>/secrets/PES_CLIENT_SECRET/versions/latest
#   PES_CLIENT_ID=
#   PES_CLIENT_SECRET=

# --- OAuth options ---
PES_OAUTH_SCOPE=provider/demographics/practitioner:read
# PES_OAUTH_AUDIENCE=
# PES_OAUTH_RESOURCE=
PES_OAUTH_CLIENT_AUTH_METHOD=post

# --- GCS location of your GraphQL query (lazy-loaded at runtime) ---
PES_GRAPHQL_QUERY_GCS=gs://ep-agent-plus-bucket/query.json

# --- Optional switches ---
PES_DYNAMIC_SUMMARY=1

# --- Logging (optional) ---
LOG_LEVEL=INFO
VERBOSE_GOOGLE_LOGS=0
# LOG_FORMAT=plain   # or 'json' for structured logs
PES_UPSTREAM_ENV=stage
